{
  "format": "knots-bundle",
  "format_version": 2,
  "workflow": {
    "name": "explore_sdlc",
    "version": 1,
    "default_profile": "explore"
  },
  "states": [
    {
      "id": "exploration",
      "display_name": "Exploration",
      "kind": "action",
      "action_kind": "produce",
      "gate_kind": null,
      "executor": "agent",
      "constraints": [],
