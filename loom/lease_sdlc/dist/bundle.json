{
  "format": "knots-bundle",
  "format_version": 2,
  "workflow": {
    "name": "lease_sdlc",
    "version": 1,
    "default_profile": "lease"
  },
  "states": [
    {
      "id": "lease_active",
      "display_name": "Lease Active",
      "kind": "action",
      "action_kind": "produce",
      "gate_kind": null,
      "executor": "agent",
      "constraints": [],
      "prompt": "lease_active",
      "output": null,
      "output_hint": null
    },
    {
      "id": "lease_terminated",
      "display_name": "Lease Terminated",
      "kind": "terminal",
      "action_kind": null,
      "gate_kind": null,
      "executor": null,
      "constraints": [],
      "prompt": null,
      "output": null,
      "output_hint": null
    },
    {
      "id": "lease_ready",
      "display_name": "Lease Ready",
      "kind": "queue",
      "action_kind": null,
      "gate_kind": null,
      "executor": null,
      "constraints": [],
      "prompt": null,
      "output": null,
      "output_hint": null
    }
  ],
  "steps": [
    {
      "id": "lease_active",
      "queue": "lease_ready",
      "action": "lease_active"
    }
  ],
  "phases": [
    {
      "id": "lease_phase",
      "produce_step": "lease_active",
      "gate_step": null
