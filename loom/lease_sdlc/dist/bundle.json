  ],
  "profiles": [
    {
      "id": "lease",
      "display_name": "Lease",
      "description": "Lease lifecycle workflow",
      "phases": [
        "lease_phase"
      ],
      "outputs": {},
      "executors": {
        "lease_active": "agent"
      }
    }
  ],
  "prompts": [
    {
      "name": "lease_active",
      "accept": [],
      "params": [],
      "outcomes": [
        {
          "name": "lease_complete",
          "target": "lease_terminated",
          "is_success": true
        }
      ],
      "body": "# Lease Active\n\nMaintain an active lease until it is explicitly terminated.",
      "body_params": []
    }
  ],
  "transitions": {
    "wildcard_targets": [],
    "queue_to_action": [
      {
        "id": "lease_active",
        "queue": "ready_for_lease_active",
        "action": "lease_active"
      }
    ],
    "outcome_tables": [
      {
        "action": "lease_active",
        "prompt": "lease_active",
        "success": {
          "lease_complete": "lease_terminated"
        },
        "failure": {}
      }
    ]
  }
